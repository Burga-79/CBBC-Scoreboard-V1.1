{
  "name": "cbbc-scoreboard",
  "version": "1.1.0",
  "description": "Comet Bay Bowling Club Scoreboard",
  "author": "Comet Bay Bowling Club",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "electron": "^28.2.0",
    "electron-builder": "^24.6.4"
  },
  "build": {
    "appId": "com.cbbc.scoreboard",
    "productName": "Comet Bay Scoreboard",

    "directories": {
      "output": "dist"
    },

    "asar": true,

    "extraResources": [
      {
        "from": "server.js",
        "to": "server.js"
      },
      {
        "from": "data",
        "to": "data"
      },
      {
        "from": "images",
        "to": "images"
      }
    ],

    "files": [
      "admin/**/*",
      "display/**/*",
      "main.js",
      "preload.js",
      "package.json",
      "node_modules/**/*"
    ]
  }
}
